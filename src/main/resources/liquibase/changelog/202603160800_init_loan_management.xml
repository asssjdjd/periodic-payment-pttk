<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="20260316-01-create-tables" author="LongPT">

        <createTable tableName="Partner">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="name" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="taxCode" type="varchar(50)"><constraints nullable="false" unique="true"/></column>
            <column name="phoneNumber" type="varchar(20)"><constraints nullable="false"/></column>
            <column name="address" type="varchar(500)"/>
            <column name="email" type="varchar(255)"/>
        </createTable>

        <createTable tableName="LendingPartner">
            <column name="id" type="bigint"><constraints primaryKey="true"/></column>
            <column name="licenseNumber" type="varchar(100)"><constraints nullable="false" unique="true"/></column>
            <column name="commissionDate" type="date"><constraints nullable="false"/></column>
        </createTable>

        <createTable tableName="Supplier">
            <column name="id" type="bigint"><constraints primaryKey="true"/></column>
            <column name="contractDate" type="date"><constraints nullable="false"/></column>
        </createTable>

        <createTable tableName="Product">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="name" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="importPrice" type="decimal(18,2)"><constraints nullable="false"/></column>
            <column name="sellingPrice" type="decimal(18,2)"><constraints nullable="false"/></column>
            <column name="status" type="varchar(50)" defaultValue="ACTIVE"><constraints nullable="false"/></column>
            <column name="supplierId" type="bigint"/>
        </createTable>

        <createTable tableName="LoanOffer">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="productId" type="bigint"><constraints nullable="false"/></column>
            <column name="name" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="interestRate" type="decimal(5,4)"><constraints nullable="false"/></column>
            <column name="penaltyRate" type="decimal(5,4)"><constraints nullable="false"/></column>
            <column name="overdueInterestRate" type="decimal(5,4)"><constraints nullable="false"/></column>
            <column name="overduePrincipleRate" type="decimal(5,4)"><constraints nullable="false"/></column>
            <column name="maxAmount" type="decimal(18,2)"><constraints nullable="false"/></column>
            <column name="termMonths" type="int"><constraints nullable="false"/></column>
        </createTable>

        <createTable tableName="User">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="name" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="email" type="varchar(255)"><constraints nullable="false" unique="true"/></column>
            <column name="phoneNumber" type="varchar(20)"/>
            <column name="userName" type="varchar(100)"><constraints nullable="false" unique="true"/></column>
            <column name="password" type="varchar(255)"><constraints nullable="false"/></column>
        </createTable>

        <createTable tableName="Customer">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="fullName" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="phoneNumber" type="varchar(20)"><constraints nullable="false"/></column>
            <column name="creditScore" type="int"/>
            <column name="status" type="varchar(50)" defaultValue="ACTIVE"><constraints nullable="false"/></column>
        </createTable>

        <createTable tableName="IndividualCustomer">
            <column name="id" type="bigint"><constraints primaryKey="true"/></column>
            <column name="cccd" type="varchar(20)"><constraints nullable="false" unique="true"/></column>
            <column name="dob" type="date"><constraints nullable="false"/></column>
        </createTable>

        <createTable tableName="BusinessCustomer">
            <column name="id" type="bigint"><constraints primaryKey="true"/></column>
        </createTable>

        <createTable tableName="Contract">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="code" type="varchar(100)"><constraints nullable="false" unique="true"/></column>
            <column name="customerId" type="bigint"><constraints nullable="false"/></column>
            <column name="userId" type="bigint"><constraints nullable="false"/></column>
            <column name="signedDate" type="date"><constraints nullable="false"/></column>
            <column name="loanProductsId" type="bigint"><constraints nullable="false"/></column>
            <column name="loanContractId" type="bigint"/>
            <column name="productPrice" type="decimal(18,2)"><constraints nullable="false"/></column>
            <column name="prepaidAmount" type="decimal(18,2)" defaultValue="0"><constraints nullable="false"/></column>
            <column name="loanAmount" type="decimal(18,2)"><constraints nullable="false"/></column>
            <column name="status" type="varchar(50)" defaultValue="ACTIVE"><constraints nullable="false"/></column>
        </createTable>

        <createTable tableName="Collateral">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="type" type="varchar(100)"><constraints nullable="false"/></column>
            <column name="description" type="text"/>
            <column name="valuationValue" type="decimal(18,2)"><constraints nullable="false"/></column>
            <column name="contractId" type="bigint"><constraints nullable="false"/></column>
        </createTable>

        <createTable tableName="LoanPaymentSchedule">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="contractId" type="bigint"><constraints nullable="false"/></column>
            <column name="scheduleId" type="bigint"/>
            <column name="termNo" type="int"><constraints nullable="false"/></column>
            <column name="dueDate" type="date"><constraints nullable="false"/></column>
            <column name="penaltyFee" type="decimal(18,2)" defaultValue="0"><constraints nullable="false"/></column>
            <column name="overdueInterest" type="decimal(18,2)" defaultValue="0"><constraints nullable="false"/></column>
            <column name="overduePrinciple" type="decimal(18,2)" defaultValue="0"><constraints nullable="false"/></column>
            <column name="interestDue" type="decimal(18,2)" defaultValue="0"><constraints nullable="false"/></column>
            <column name="principalDue" type="decimal(18,2)" defaultValue="0"><constraints nullable="false"/></column>
            <column name="penaltyDue" type="decimal(18,2)" defaultValue="0"><constraints nullable="false"/></column>
            <column name="status" type="varchar(50)" defaultValue="PENDING"><constraints nullable="false"/></column>
            <column name="penaltyFeePaid" type="decimal(18,2)" defaultValue="0"><constraints nullable="false"/></column>
            <column name="overdueInterestPaid" type="decimal(18,2)" defaultValue="0"><constraints nullable="false"/></column>
            <column name="overduePrinciplePaid" type="decimal(18,2)" defaultValue="0"><constraints nullable="false"/></column>
            <column name="interestPaid" type="decimal(18,2)" defaultValue="0"><constraints nullable="false"/></column>
            <column name="principlePaid" type="decimal(18,2)" defaultValue="0"><constraints nullable="false"/></column>
        </createTable>
        <addUniqueConstraint tableName="LoanPaymentSchedule" columnNames="contractId, termNo" constraintName="uq_schedule_term"/>

        <createTable tableName="LoanTransaction">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="transactionDate" type="datetime" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/></column>
            <column name="amountPaid" type="decimal(18,2)"><constraints nullable="false"/></column>
            <column name="paymentMethod" type="varchar(100)"><constraints nullable="false"/></column>
            <column name="note" type="text"/>
            <column name="userId" type="bigint"><constraints nullable="false"/></column>
        </createTable>

        <createTable tableName="TransactionLoanPaymentSchedule">
            <column name="id" type="bigint" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="loanTransactionId" type="bigint"><constraints nullable="false"/></column>
            <column name="loanPaymentScheduleId" type="bigint"><constraints nullable="false"/></column>
            <column name="contractId" type="bigint"><constraints nullable="false"/></column>
        </createTable>
        <addUniqueConstraint tableName="TransactionLoanPaymentSchedule" columnNames="loanTransactionId, loanPaymentScheduleId" constraintName="uq_txn_schedule"/>
    </changeSet>

    <changeSet id="20260316-02-add-foreign-keys" author="LomgPT">
        <addForeignKeyConstraint baseTableName="LendingPartner" baseColumnNames="id" constraintName="fk_lendingpartner_partner" referencedTableName="Partner" referencedColumnNames="id" onDelete="CASCADE" onUpdate="CASCADE"/>
        <addForeignKeyConstraint baseTableName="Supplier" baseColumnNames="id" constraintName="fk_supplier_partner" referencedTableName="Partner" referencedColumnNames="id" onDelete="CASCADE" onUpdate="CASCADE"/>

        <addForeignKeyConstraint baseTableName="Product" baseColumnNames="supplierId" constraintName="fk_product_supplier" referencedTableName="Supplier" referencedColumnNames="id" onDelete="SET NULL" onUpdate="CASCADE"/>
        <addForeignKeyConstraint baseTableName="LoanOffer" baseColumnNames="productId" constraintName="fk_loanoffer_product" referencedTableName="Product" referencedColumnNames="id" onDelete="RESTRICT" onUpdate="CASCADE"/>

        <addForeignKeyConstraint baseTableName="IndividualCustomer" baseColumnNames="id" constraintName="fk_individualcustomer_customer" referencedTableName="Customer" referencedColumnNames="id" onDelete="CASCADE" onUpdate="CASCADE"/>
        <addForeignKeyConstraint baseTableName="BusinessCustomer" baseColumnNames="id" constraintName="fk_businesscustomer_customer" referencedTableName="Customer" referencedColumnNames="id" onDelete="CASCADE" onUpdate="CASCADE"/>

        <addForeignKeyConstraint baseTableName="Contract" baseColumnNames="customerId" constraintName="fk_contract_customer" referencedTableName="Customer" referencedColumnNames="id" onDelete="RESTRICT" onUpdate="CASCADE"/>
        <addForeignKeyConstraint baseTableName="Contract" baseColumnNames="userId" constraintName="fk_contract_user" referencedTableName="User" referencedColumnNames="id" onDelete="RESTRICT" onUpdate="CASCADE"/>
        <addForeignKeyConstraint baseTableName="Contract" baseColumnNames="loanProductsId" constraintName="fk_contract_loanoffer" referencedTableName="LoanOffer" referencedColumnNames="id" onDelete="RESTRICT" onUpdate="CASCADE"/>
        <addForeignKeyConstraint baseTableName="Contract" baseColumnNames="loanContractId" constraintName="fk_contract_loancontract" referencedTableName="Contract" referencedColumnNames="id" onDelete="SET NULL" onUpdate="CASCADE"/>

        <addForeignKeyConstraint baseTableName="Collateral" baseColumnNames="contractId" constraintName="fk_collateral_contract" referencedTableName="Contract" referencedColumnNames="id" onDelete="CASCADE" onUpdate="CASCADE"/>

        <addForeignKeyConstraint baseTableName="LoanPaymentSchedule" baseColumnNames="contractId" constraintName="fk_loanschedule_contract" referencedTableName="Contract" referencedColumnNames="id" onDelete="RESTRICT" onUpdate="CASCADE"/>

        <addForeignKeyConstraint baseTableName="LoanTransaction" baseColumnNames="userId" constraintName="fk_loantransaction_user" referencedTableName="User" referencedColumnNames="id" onDelete="RESTRICT" onUpdate="CASCADE"/>

        <addForeignKeyConstraint baseTableName="TransactionLoanPaymentSchedule" baseColumnNames="loanTransactionId" constraintName="fk_txnschedule_transaction" referencedTableName="LoanTransaction" referencedColumnNames="id" onDelete="CASCADE" onUpdate="CASCADE"/>
        <addForeignKeyConstraint baseTableName="TransactionLoanPaymentSchedule" baseColumnNames="loanPaymentScheduleId" constraintName="fk_txnschedule_schedule" referencedTableName="LoanPaymentSchedule" referencedColumnNames="id" onDelete="CASCADE" onUpdate="CASCADE"/>
        <addForeignKeyConstraint baseTableName="TransactionLoanPaymentSchedule" baseColumnNames="contractId" constraintName="fk_txnschedule_contract" referencedTableName="Contract" referencedColumnNames="id" onDelete="RESTRICT" onUpdate="CASCADE"/>
    </changeSet>

    <changeSet id="20260316-03-add-indexes-and-checks" author="LongPT">
        <createIndex tableName="Product" indexName="idx_product_supplier"><column name="supplierId"/></createIndex>
        <createIndex tableName="LoanOffer" indexName="idx_loanoffer_product"><column name="productId"/></createIndex>
        <createIndex tableName="Contract" indexName="idx_contract_customer"><column name="customerId"/></createIndex>
        <createIndex tableName="Contract" indexName="idx_contract_user"><column name="userId"/></createIndex>
        <createIndex tableName="Contract" indexName="idx_contract_loanoffer"><column name="loanProductsId"/></createIndex>
        <createIndex tableName="Collateral" indexName="idx_collateral_contract"><column name="contractId"/></createIndex>
        <createIndex tableName="LoanPaymentSchedule" indexName="idx_schedule_contract"><column name="contractId"/></createIndex>
        <createIndex tableName="LoanPaymentSchedule" indexName="idx_schedule_duedate"><column name="dueDate"/></createIndex>
        <createIndex tableName="LoanTransaction" indexName="idx_transaction_user"><column name="userId"/></createIndex>
        <createIndex tableName="LoanTransaction" indexName="idx_transaction_date"><column name="transactionDate"/></createIndex>
        <createIndex tableName="TransactionLoanPaymentSchedule" indexName="idx_txnschedule_txn"><column name="loanTransactionId"/></createIndex>
        <createIndex tableName="TransactionLoanPaymentSchedule" indexName="idx_txnschedule_schedule"><column name="loanPaymentScheduleId"/></createIndex>

        <sql>
            ALTER TABLE Product ADD CHECK (importPrice >= 0);
            ALTER TABLE Product ADD CHECK (sellingPrice >= 0);

            ALTER TABLE LoanOffer ADD CHECK (interestRate >= 0);
            ALTER TABLE LoanOffer ADD CHECK (penaltyRate >= 0);
            ALTER TABLE LoanOffer ADD CHECK (overdueInterestRate >= 0);
            ALTER TABLE LoanOffer ADD CHECK (overduePrincipleRate >= 0);
            ALTER TABLE LoanOffer ADD CHECK (maxAmount > 0);
            ALTER TABLE LoanOffer ADD CHECK (termMonths > 0);

            ALTER TABLE Customer ADD CHECK (creditScore BETWEEN 0 AND 1000);

            ALTER TABLE Contract ADD CHECK (productPrice >= 0);
            ALTER TABLE Contract ADD CHECK (prepaidAmount >= 0);
            ALTER TABLE Contract ADD CHECK (loanAmount > 0);
            ALTER TABLE Contract ADD CONSTRAINT chk_prepaid_lte_price CHECK (prepaidAmount &lt;= productPrice);

            ALTER TABLE Collateral ADD CHECK (valuationValue >= 0);

            ALTER TABLE LoanPaymentSchedule ADD CHECK (termNo > 0);
            ALTER TABLE LoanPaymentSchedule ADD CHECK (penaltyFee >= 0);
            ALTER TABLE LoanPaymentSchedule ADD CHECK (overdueInterest >= 0);
            ALTER TABLE LoanPaymentSchedule ADD CHECK (overduePrinciple >= 0);
            ALTER TABLE LoanPaymentSchedule ADD CHECK (interestDue >= 0);
            ALTER TABLE LoanPaymentSchedule ADD CHECK (principalDue >= 0);
            ALTER TABLE LoanPaymentSchedule ADD CHECK (penaltyDue >= 0);
            ALTER TABLE LoanPaymentSchedule ADD CHECK (penaltyFeePaid >= 0);
            ALTER TABLE LoanPaymentSchedule ADD CHECK (overdueInterestPaid >= 0);
            ALTER TABLE LoanPaymentSchedule ADD CHECK (overduePrinciplePaid >= 0);
            ALTER TABLE LoanPaymentSchedule ADD CHECK (interestPaid >= 0);
            ALTER TABLE LoanPaymentSchedule ADD CHECK (principlePaid >= 0);

            ALTER TABLE LoanTransaction ADD CHECK (amountPaid > 0);
        </sql>
    </changeSet>

</databaseChangeLog>